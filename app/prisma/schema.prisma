generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Poll {
  id         Int      @id @default(autoincrement())
  question   String   @unique
  text       Json
  is_active  Boolean  @default(true)
  expires_at DateTime? @db.Timestamptz

  @@map("polls_poll")
}